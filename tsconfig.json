{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/app/*": [
        "./app/*"
      ],
      "@/shell/*": [
        "./shell/*"
      ],
      "@/configs/*": [
        "./configs/*"
      ],
      "@hrtbrxkxr/shared-ui": [
        "./packages/shared-ui/src/index.ts"
      ],
      "@hrtbrxkxr/shared-ui/*": [
        "./packages/shared-ui/src/*"
      ],
      "@hrtbrxkxr/shared-utils": [
        "./packages/shared-utils/src/index.ts"
      ],
      "@hrtbrxkxr/shared-utils/*": [
        "./packages/shared-utils/src/*"
      ],
      "@platform/branding": [
        "./branding/index.ts"
      ],
      "@platform/branding/*": [
        "./branding/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "shell/**/*.ts",
    "shell/**/*.tsx",
    "configs/**/*.ts",
    "tests/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    "modules",
    "packages",
    ".next"
  ]
}
