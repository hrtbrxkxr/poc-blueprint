# Consumer identity
NEXT_PUBLIC_CONSUMER_ID=consumer-a
NEXT_PUBLIC_ENV=development

# Backend services
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- Local dev fallback values for the Vault-managed keys below ---
# In staging/production these five are NOT read from here: instrumentation.ts
# calls shell/services/secrets.service.ts at server boot, which overwrites them
# from Vault before the app serves any traffic. See docs/secrets-management.md.
THEME_SERVICE_URL=http://localhost:8080/theme
AUTH_SERVICE_URL=http://localhost:8080/auth
MAINTENANCE_SERVICE_URL=http://localhost:8080/maintenance
JWT_PUBLIC_KEY_URL=http://localhost:8080/auth/.well-known/jwks.json
JWT_ISSUER=https://auth.platform.local
JWT_AUDIENCE=consumer-a

# Module BFF endpoints (consumed by shell module loader — not secret, safe to keep here)
NEXT_PUBLIC_MODULE_A_BFF_URL=http://localhost:4001
NEXT_PUBLIC_MODULE_B_BFF_URL=http://localhost:4002
NEXT_PUBLIC_MODULE_C_BFF_URL=http://localhost:4003

# --- Vault AppRole credentials ---
# Leave all three unset for local dev: hydrateEnvFromVault() then no-ops and the
# plaintext values above are used as-is. In staging/production these are injected
# by the deploy platform (Vercel/K8s secret), never committed.
VAULT_ADDR=https://vault.internal:8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_SECRET_PATH=secret/data/consumer-a
